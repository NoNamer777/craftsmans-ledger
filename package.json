{
  "name": "craftsmans-ledger",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A personal companion tool for Medieval Dynasty: track unlocked recipes, find vendors across villages/realms, compare recipe profitability, and look up recipes/items/buildings by tech-tree progression.",
  "license": "MIT",
  "homepage": "https://github.com/nonamer777/craftsmans-ledger#readme",
  "bugs": {
    "url": "https://github.com/nonamer777/craftsmans-ledger/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nonamer777/craftsmans-ledger.git"
  },
  "engines": {
    "node": "24.18.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "prepare": "husky"
  },
  "dependencies": {
    "@angular/common": "catalog:angular",
    "@angular/core": "~22.0.5",
    "@angular/platform-browser": "catalog:angular",
    "@angular/router": "catalog:angular"
  },
  "devDependencies": {
    "@angular/build": "catalog:angular",
    "@angular/cli": "catalog:angular",
    "@angular/compiler-cli": "catalog:angular",
    "@commitlint/cli": "catalog:tooling",
    "@commitlint/config-conventional": "catalog:tooling",
    "@craftsmans-ledger/eslint-config": "workspace:*",
    "@craftsmans-ledger/tsconfig": "workspace:*",
    "@moonrepo/cli": "catalog:tooling",
    "@types/node": "catalog:tooling",
    "@vitest/browser-playwright": "~4.1.9",
    "@vitest/coverage-v8": "~4.1.9",
    "@vitest/ui": "~4.1.9",
    "eslint": "catalog:tooling",
    "husky": "catalog:tooling",
    "jiti": "catalog:tooling",
    "lint-staged": "catalog:tooling",
    "prettier": "catalog:tooling",
    "prettier-plugin-organize-imports": "catalog:tooling",
    "prettier-plugin-tailwindcss": "catalog:tooling",
    "stylelint": "catalog:tooling",
    "typescript": "catalog:tooling",
    "vitest": "~4.1.9"
  }
}
