{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "cli": {
        "packageManager": "pnpm",
        "analytics": false
    },
    "newProjectRoot": "libs",
    "schematics": {
        "@schematics/angular:component": {
            "changeDetection": "OnPush",
            "style": "scss"
        }
    },
    "projects": {
        "web": {
            "projectType": "application",
            "root": "apps/web",
            "sourceRoot": "apps/web/src",
            "prefix": "web",
            "architect": {
                "build": {
                    "builder": "@angular/build:application",
                    "options": {
                        "assets": [
                            {
                                "input": "apps/web/public",
                                "glob": "**/*"
                            }
                        ],
                        "browser": "apps/web/src/main.ts",
                        "inlineStyleLanguage": "scss",
                        "outputPath": {
                            "base": "apps/web/dist"
                        },
                        "sourceMap": true,
                        "styles": ["apps/web/src/styles.scss"],
                        "tsConfig": "apps/web/tsconfig.app.json"
                    },
                    "defaultConfiguration": "production",
                    "configurations": {
                        "production": {
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "500kB",
                                    "maximumError": "1MB"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "4kB",
                                    "maximumError": "8kB"
                                }
                            ],
                            "outputHashing": "all",
                            "subresourceIntegrity": true
                        },
                        "development": {
                            "namedChunks": true,
                            "extractLicenses": false,
                            "optimization": false
                        }
                    }
                },
                "serve": {
                    "builder": "@angular/build:dev-server",
                    "options": {
                        "buildTarget": "web:build:development",
                        "host": "127.0.0.1",
                        "port": 8080,
                        "ssl": true,
                        "sslCert": "../../.certs/cert.pem",
                        "sslKey": "../../.certs/key.pem",
                        "allowedHosts": ["localhost.www.craftsmans-ledger.dev"]
                    }
                },
                "test": {
                    "builder": "@angular/build:unit-test",
                    "options": {
                        "browsers": ["chromium"],
                        "coverage": true,
                        "coverageExclude": ["src/main.ts", "src/*/config/**"],
                        "coverageReporters": ["html", "text-summary"],
                        "coverageThresholds": {
                            "statements": 80,
                            "branches": 80,
                            "functions": 80,
                            "lines": 80
                        },
                        "headless": true,
                        "include": ["**/*.spec.ts"],
                        "runnerConfig": "apps/web/vitest.config.mts",
                        "tsConfig": "apps/web/tsconfig.spec.json"
                    },
                    "defaultConfiguration": "development",
                    "configurations": {
                        "development": {
                            "reporters": ["dot", ["html", { "outputFile": "reports/index.html" }]],
                            "ui": true,
                            "watch": true
                        },
                        "ci": {
                            "reporters": ["dot", "github-actions", ["html", { "outputFile": "reports/index.html" }]],
                            "watch": false
                        }
                    }
                }
            }
        }
    }
}
